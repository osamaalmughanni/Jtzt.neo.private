{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "frontend/src/*"
      ],
      "@shared/*": [
        "shared/*"
      ],
      "@frontend/*": [
        "frontend/src/*"
      ],
      "@backend/*": [
        "backend/*"
      ]
    }
  }
}
