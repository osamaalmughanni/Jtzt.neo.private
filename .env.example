# =========================================================
# ESSENTIAL
# Fill these yourself. This single file is the source of truth
# for local Node dev, local Wrangler dev, and Cloudflare deploy.
# =========================================================

JWT_SECRET="replace-with-a-long-random-secret"
CLOUDFLARE_WORKER_NAME="jtzt-app"
CLOUDFLARE_COMPATIBILITY_DATE="2026-03-19"
CLOUDFLARE_D1_BINDING="DB"
CLOUDFLARE_D1_DATABASE_NAME="jtzt-app"
CLOUDFLARE_D1_DATABASE_ID="replace-with-your-d1-database-id"

# =========================================================
# ESSENTIAL RUNTIME
# Safe defaults exist, but production should set these intentionally.
# =========================================================

APP_ENV="development"
APP_VERSION="dev"
SESSION_TTL_HOURS="12"
NODE_SQLITE_PATH="data/app.db"
ADMIN_BOOTSTRAP_USERNAME="admin"
ADMIN_BOOTSTRAP_PASSWORD="change-this-now"

# =========================================================
# OPTIONAL CLOUDFLARE
# Fill only if needed for your account or routing.
# =========================================================

CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_CUSTOM_DOMAIN=""

# =========================================================
# OPTIONAL PATHS
# Leave these alone unless you intentionally move things.
# =========================================================

CLOUDFLARE_WRANGLER_CONFIG="cloudflare/wrangler.jsonc"
CLOUDFLARE_WORKER_ENTRY="cloudflare/worker/index.ts"
CLOUDFLARE_MIGRATIONS_DIR="cloudflare/d1/migrations"
CLOUDFLARE_ASSETS_DIR="dist/frontend"
CLOUDFLARE_ASSETS_NOT_FOUND_HANDLING="single-page-application"
