{
  "name": "jtzt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:backend": "tsx watch backend/server.ts",
    "build": "npm run build:backend && npm run build:frontend",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:backend": "tsc -p tsconfig.backend.json",
    "typecheck": "tsc -p tsconfig.backend.json --noEmit && tsc -p frontend/tsconfig.json --noEmit",
    "test:time": "tsx tests/time-system.test.ts",
    "cf:wrangler:version": "wrangler --version",
    "cf:doctor": "python .deploy.py doctor",
    "cf:prepare-dev": "python .deploy.py prepare-dev",
    "cf:dev": "python .deploy.py prepare-dev && wrangler dev --config cloudflare/wrangler.jsonc",
    "cf:write-config": "python .deploy.py write-config",
    "cf:d1:create": "python .deploy.py d1-create",
    "cf:migrate:local": "python .deploy.py migrate-local",
    "cf:migrate:remote": "python .deploy.py migrate-remote",
    "cf:set-secret": "python .deploy.py set-secret",
    "cf:deploy": "python .deploy.py deploy",
    "cf:full": "python .deploy.py full"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hookform/resolvers": "^3.9.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "hono": "^4.6.10",
    "i18next": "^25.8.18",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.453.0",
    "phosphor-react": "^1.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-i18next": "^16.5.8",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.8.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^7.1.7",
    "wrangler": "^4.75.0"
  }
}
