{
  "name": "jtzt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:frontend": "vite --force --config ./frontend/vite.config.ts",
    "dev:backend": "concurrently \"npm:dev:backend:build\" \"npm:dev:backend:serve\"",
    "dev:backend:build": "node tools/run-esbuild.mjs backend-watch",
    "dev:backend:serve": "node tools/dev-backend-serve.mjs",
    "build": "npm run build:backend && npm run build:frontend",
    "build:frontend": "vite build --config ./frontend/vite.config.ts",
    "build:backend": "node -e \"const fs=require('fs');const path=require('path');fs.rmSync('dist/backend',{recursive:true,force:true});\" && node tools/run-esbuild.mjs backend && node -e \"const fs=require('fs');const path=require('path');const src=path.join(process.cwd(),'backend','services','calculation-presets');const dst=path.join(process.cwd(),'dist','backend','services','calculation-presets');if(fs.existsSync(src)){fs.mkdirSync(dst,{recursive:true});for(const file of fs.readdirSync(src)){if(file.endsWith('.js')) fs.copyFileSync(path.join(src,file),path.join(dst,file));}}\"",
    "db:generate:system": "drizzle-kit generate --config drizzle.system.config.ts",
    "db:generate:company": "drizzle-kit generate --config drizzle.company.config.ts",
    "db:generate": "npm run db:generate:system && npm run db:generate:company",
    "db:migrate": "tsx tools/run-drizzle-migrations.ts",
    "db:migrate:system": "tsx tools/run-drizzle-migrations.ts system",
    "db:migrate:companies": "tsx tools/run-drizzle-migrations.ts companies",
    "demo:seed:build": "node tools/run-esbuild.mjs demo-seed",
    "demo:seed": "npm run demo:seed:build && node dist/tools/seed-demo.js",
    "typecheck": "tsc -p tsconfig.backend.json --noEmit && tsc -p frontend/tsconfig.json --noEmit",
    "clean:translations": "node tools/clean-unused-translations.mjs --write",
    "deploy:doctor": "python .deploy.py doctor",
    "deploy:bootstrap": "python .deploy.py bootstrap",
    "deploy:build": "python .deploy.py build",
    "deploy:typecheck": "python .deploy.py typecheck",
    "deploy:push": "python .deploy.py deploy",
    "deploy:status": "python .deploy.py status",
    "deploy:rollback": "python .deploy.py rollback",
    "deploy:logs": "python .deploy.py logs",
    "deploy:full": "python .deploy.py full"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hookform/resolvers": "^3.9.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vvo/tzdb": "^6.198.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "framer-motion": "^11.11.17",
    "hono": "^4.6.10",
    "i18n-iso-countries": "^7.14.0",
    "i18next": "^25.8.18",
    "jsonwebtoken": "^9.0.2",
    "locale-codes": "^1.3.1",
    "lucide-react": "^0.453.0",
    "phosphor-react": "^1.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-i18next": "^16.5.8",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.13.2",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.8.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^7.1.7"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.27.4"
    }
  }
}
